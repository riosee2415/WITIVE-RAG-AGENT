# =============================================================================
# WITIVE Knowledge AI — .env.example
#
# 이 파일은 환경 변수 키 이름과 기본값/형식을 보여주는 템플릿이다.
# 실제 시크릿은 .env (git ignore) 또는 시스템 환경 변수에 박는다.
# 단일 진실 출처: docs/10-config-and-secrets.md §2
# =============================================================================


# -----------------------------------------------------------------------------
# 서버·런타임 (10 §2.1)
# -----------------------------------------------------------------------------
ENV=dev                                    # dev / staging / prod
LOG_LEVEL=DEBUG                            # DEBUG / INFO / WARNING / ERROR
MAX_EXPECTED_TASKS=2                       # ECS Auto Scaling max — Redis 장애 fallback 산정 (dev:2 / staging:5 / prod:20)
MAINTENANCE_MODE=false                     # true 시 모든 query 503


# -----------------------------------------------------------------------------
# 인증·Next.js contract (10 §2.2 / 00 §3)
# -----------------------------------------------------------------------------
# dual-key 회전 (00 §3.1)
INTERNAL_AUTH_SECRET_PRIMARY=
INTERNAL_AUTH_SECRET_SECONDARY=

# 직급 매핑 (07 §1.4)
LEVEL_RANK_JSON={"사원":1,"주임":2,"대리":3,"과장":4,"차장":5,"부장":6,"이사":7,"상무":8,"전무":9,"사장":10}

# 시스템 호출 reserved UUID (00 §3.2)
SYSTEM_CRON_USER_ID=00000000-0000-0000-0000-000000000001


# -----------------------------------------------------------------------------
# Bedrock·LLM (10 §2.3 / 05)
# -----------------------------------------------------------------------------
BEDROCK_REGION=ap-northeast-2
BEDROCK_MODEL_STAGE1=anthropic.claude-haiku-4-5-v1:0
BEDROCK_MODEL_STAGE2=anthropic.claude-haiku-4-5-v1:0   # dev: Haiku / staging·prod: anthropic.claude-sonnet-4-6-v1:0
BEDROCK_MODEL_EMBEDDING=amazon.titan-embed-text-v2:0

# Stage 1·2 호출 파라미터
STAGE1_TIMEOUT_S=3.0
STAGE2_GEN_TIMEOUT_S=30
STAGE1_MAX_TOKENS=300
STAGE2_MAX_TOKENS=1024
STAGE1_TEMP=0.1
STAGE2_TEMP=0.3
STAGE1_TOP_P=1.0
STAGE2_TOP_P=0.9

# Bedrock prompt cache (05 §4.2)
STAGE2_SYSTEM_PROMPT_TARGET_TOKENS=1200
STAGE2_SYSTEM_PROMPT_MIN_TOKENS=1024

# Titan 글로벌 rate limit (05 §5.2)
BEDROCK_TITAN_RPS_LIMIT=10                 # dev:10 / staging:20 / prod:30
BEDROCK_TITAN_BURST=60
EMBED_BATCH_SIZE=20
MAX_CONCURRENT_EMBED_BATCHES=4
EMBED_QUERY_TIMEOUT_MS=300


# -----------------------------------------------------------------------------
# Bedrock 비용 단가 (USD per 1M tokens, 09 §2.4)
# -----------------------------------------------------------------------------
BEDROCK_PRICE_INPUT_HAIKU_USD_PER_1M=
BEDROCK_PRICE_OUTPUT_HAIKU_USD_PER_1M=
BEDROCK_PRICE_CACHE_READ_HAIKU_USD_PER_1M=
BEDROCK_PRICE_INPUT_SONNET_USD_PER_1M=
BEDROCK_PRICE_OUTPUT_SONNET_USD_PER_1M=
BEDROCK_PRICE_CACHE_READ_SONNET_USD_PER_1M=
BEDROCK_PRICE_INPUT_TITAN_USD_PER_1M=


# -----------------------------------------------------------------------------
# Pinecone (10 §2.4)
# -----------------------------------------------------------------------------
PINECONE_API_KEY=
PINECONE_TOP_K=10
PINECONE_TIMEOUT_MS=500
PINECONE_UPSERT_BATCH=100
SIM_THRESHOLD_HIGH=0.75
SIM_THRESHOLD_LOW=0.60
SIM_THRESHOLD_FALLBACK=0.55


# -----------------------------------------------------------------------------
# Neo4j (10 §2.5) — dev 환경에서는 미사용 (빈 값 허용)
# -----------------------------------------------------------------------------
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
NEO4J_LIMIT=10
NEO4J_TIMEOUT_MS=1000
NEO4J_USE_APOC=false
NEO4J_USE_TOKENIZED_FIELD=false
NEO4J_MAX_TRANSACTION_RETRY_TIME_S=5
CHUNK_TEXT_NEO4J_TIMEOUT_MS=100


# -----------------------------------------------------------------------------
# S3·KMS (10 §2.6)
# -----------------------------------------------------------------------------
S3_BUCKET_DOCS=witive-docs-dev              # 환경별 다름
S3_REGION=ap-northeast-2
KMS_KEY_ALIAS_PREFIX=alias/witive-tenant-
MAX_UPLOAD_BYTES=104857600                  # 100MB
ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/html
CHUNK_TEXT_S3_TIMEOUT_MS=500


# -----------------------------------------------------------------------------
# Redis / ElastiCache (10 §2.7)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0          # 로컬 / staging·prod: rediss://...
REDIS_AUTH_TOKEN=
QUERY_CACHE_TTL_BUSINESS_S=300              # dev:300 / staging:60 / prod:60 (적응형)
QUERY_CACHE_TTL_OFF_S=300                   # dev:300 / staging:60 / prod:300
CACHE_REPLAY_CHUNK_CHARS=32
JOB_CACHE_TTL_S=5
DUP_QUERY_WINDOW_S=60
DUP_QUERY_THRESHOLD=3
CACHE_INVALIDATE_RATE_PER_MIN=60


# -----------------------------------------------------------------------------
# SQS·Worker (10 §2.8)
# -----------------------------------------------------------------------------
SQS_QUEUE_URL=
SQS_DLQ_URL=
SQS_VISIBILITY_TIMEOUT_S=300
MAX_CONCURRENT_DOCS=1                       # dev:1 / staging:2 / prod:4
WORKER_MESSAGE_DEADLINE_S=270


# -----------------------------------------------------------------------------
# 색인·청킹 (10 §2.9)
# -----------------------------------------------------------------------------
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=50
CHUNK_MIN_TOKENS=50
CHUNK_MAX_TOKENS=1024
OCR_FALLBACK_CHAR_PER_PAGE=100
OCR_MIN_CONFIDENCE=0.70
CONFLICT_SIMILARITY_THRESHOLD=0.92
STAGE_B_STEP_RETRIES=3
STAGE_B_DEADLINE_S=60


# -----------------------------------------------------------------------------
# 입력 검증·SSE·SLO (10 §2.10)
# -----------------------------------------------------------------------------
QUERY_MIN_LEN=1
QUERY_MAX_LEN=2000
RERANK_TOP_K=5
RERANK_TIMEOUT_MS=1500
MAX_CONCURRENT_SSE_CONNECTIONS=50           # dev:50 / staging:100 / prod:200
QUERY_REQUEST_DEADLINE_S=60
SLO_FIRST_TOKEN_P95_MS=4000


# -----------------------------------------------------------------------------
# 서킷 브레이커 (10 §2.11 / 08 §3.1)
# -----------------------------------------------------------------------------
CB_BEDROCK_FAIL_THRESHOLD=0.50
CB_BEDROCK_WINDOW_S=10
CB_BEDROCK_OPEN_S=30
CB_PINECONE_FAIL_THRESHOLD=0.30
CB_PINECONE_WINDOW_S=10
CB_PINECONE_OPEN_S=30
CB_NEO4J_FAIL_THRESHOLD=0.30
CB_NEO4J_WINDOW_S=10
CB_NEO4J_OPEN_S=30
CB_REDIS_FAIL_THRESHOLD=0.50
CB_REDIS_WINDOW_S=5
CB_REDIS_OPEN_S=10


# -----------------------------------------------------------------------------
# 관찰가능성 (10 §2.12 / 09)
# -----------------------------------------------------------------------------
XRAY_ENABLED=true
EMF_NAMESPACE=WitiveRagAi
EMF_NAMESPACE_PER_TENANT=WitiveRagAi/PerTenant
PER_TENANT_METRIC_TENANT_IDS=               # csv 화이트리스트 (≤ 50개)
LOG_LLM_RESPONSE_BODY=false


# =============================================================================
# 하네스·외부 도구 (.claude/SETUP.md)
# =============================================================================


# -----------------------------------------------------------------------------
# Gmail SMTP (이메일 발송 — /review-check, /rubric)
# -----------------------------------------------------------------------------
# 발급: Google 계정 → 보안 → 2단계 인증 → 앱 비밀번호 → 16자
GMAIL_SMTP_USER=upustream@gmail.com
GMAIL_SMTP_APP_PASSWORD=
GMAIL_SMTP_FROM=upustream@gmail.com
GMAIL_SMTP_TO=upustream@gmail.com


# -----------------------------------------------------------------------------
# MCP — AWS Labs (.mcp.json aws)
# -----------------------------------------------------------------------------
# AWS profile 사전 셋업: aws configure --profile witive-dev
AWS_PROFILE=witive-dev
AWS_REGION=ap-northeast-2


# -----------------------------------------------------------------------------
# MCP — GitHub (.mcp.json github)
# -----------------------------------------------------------------------------
# 발급: GitHub → Settings → Developer settings → Fine-grained tokens
# 권한: repo, pull_requests:write, issues:write, read:org
GITHUB_PERSONAL_ACCESS_TOKEN=


# -----------------------------------------------------------------------------
# 외부 시스템 토큰 (있을 시, 03 §5 URL/API 등록)
# -----------------------------------------------------------------------------
# witive/{env}/external/{tenant_id}/{integration_id} (Secrets Manager)
# 본 .env에는 박지 않고 runtime에 Secrets Manager에서 fetch
